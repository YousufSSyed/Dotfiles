sanitize tridactyllocal tridactylsync
alias refresh source ~/.config/tridactyl/tridactylrc

unbind <C-f>
unbind <C-b>
unbind --mode=ex <Space>
unbind d
unbind yc
unbind <C-a>

set smoothscroll true
bind j scrollline 10
bind k scrollline -10

" bindurl ^https://wafflegame.net* F hint -qhb -c [class*="draggable"]

" Misc bindings
bind h tabprev
bind l tabnext
bind H back
bind L forward
bind d hint
bind f hint -b
bind F hint -qb
" bind --mode=hint f hint.reset; mode normal
bind T fillcmdline undo
bind <m-T> refresh 
bind t fillcmdline taball
bind yt tabduplicate
bind --mode=ignore <Escape> mode normal
bind i mode ignore
bind --mode=ex <ArrowUp> ex.prev_completion
bind --mode=ex <ArrowDown> ex.next_completion
bind --mode=visual s composite js document.getSelection().toString() | tabopen -b search

colorscheme theme

" Remove all styling from hints
set hintstyles.bg none
set hintstyles.fg none
set hintstyles.outline none
set tabsort mru

set newtab about:blank

" Copy a selected link in markdown format
bind ym composite hint a -JF e=>`[${e.textContent.trim()}](${e.href})` | yank

" Open all URLS in clipboard, separated by newlines
bind yc jsb navigator.clipboard.readText().then(text => { let urls = text.split('\n') .map(url => url.trim()) .filter(url => url.length > 0); urls.forEach(url => { browser.tabs.create({ url: url, active: false, discarded: true }); }); });

" Copy URLs of all selected tabs
bind yl jsb browser.tabs.query({ highlighted: true, currentWindow: true }, (tabs) => { navigator.clipboard.writeText(tabs.map(tab => tab.url).join('\n')); });

" Copy all selected tabs in markdown
bind yL jsb browser.tabs.query({ highlighted: true, currentWindow: true }, (tabs) => { navigator.clipboard.writeText(tabs.map(tab => `[${tab.title}](${tab.url})`).join('\n')); });

bind yd jsb browser.tabs.query({ highlighted: true, currentWindow: true }, (tabs) => { navigator.clipboard.writeText(tabs.map(tab => tab.url).join(' ')); });

