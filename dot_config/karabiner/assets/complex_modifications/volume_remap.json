{
	"title": "Remap Volume Keys to Option+Shift+F11/F12",
	"rules": [
		{
			"description": "Remap Volume Down to ⌥+⇧+F11 and Volume Up to ⌥+⇧+F12",
			"manipulators": [
				{
					"type": "basic",
					"from": {
						"consumer_key_code": "volume_decrement"
					},
					"to": [
						{
							"key_code": "f11",
							"modifiers": ["option", "shift"]
						},
						{
							"key_code": "f11",
							"modifiers": ["option", "shift"]
						}
					]
				},
				{
					"type": "basic",
					"from": {
						"consumer_key_code": "volume_increment"
					},
					"to": [
						{
							"key_code": "f12",
							"modifiers": ["option", "shift"]
						},
						{
							"key_code": "f12",
							"modifiers": ["option", "shift"]
						}
					]
				}
			]
		}
	]
}
