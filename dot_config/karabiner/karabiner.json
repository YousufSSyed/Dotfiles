{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Remap Volume Down to ⌥+⇧+F11 and Volume Up to ⌥+⇧+F12",
                        "manipulators": [
                            {
                                "from": { "consumer_key_code": "volume_decrement" },
                                "to": [
                                    {
                                        "key_code": "f11",
                                        "modifiers": ["option", "shift"]
                                    },
                                    {
                                        "key_code": "f11",
                                        "modifiers": ["option", "shift"]
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": { "consumer_key_code": "volume_increment" },
                                "to": [
                                    {
                                        "key_code": "f12",
                                        "modifiers": ["option", "shift"]
                                    },
                                    {
                                        "key_code": "f12",
                                        "modifiers": ["option", "shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Left ctrl + hjkl to arrow keys Vim",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "left_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "j",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "k",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "right_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Roblox map semicolon to left click",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^$"
                                        ],
                                        "file_paths": ["^/Applications/Roblox.app", "^/Applications/Roblox.app/Contents/MacOS/Roblox.app", "^/Applications/Roblox.app/Contents/MacOS/Roblox.app/Contents/MacOS/Roblox"],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": { "key_code": "semicolon" },
                                "to": [{ "pointing_button": "button1" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "product_id": 45092,
                        "vendor_id": 1133
                    },
                    "simple_modifications": [
                        {
                            "from": { "pointing_button": "button3" },
                            "to": [{ "key_code": "vk_none" }]
                        },
                        {
                            "from": { "pointing_button": "button5" },
                            "to": [{ "key_code": "vk_none" }]
                        }
                    ]
                }
            ],
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "caps_lock" },
                    "to": [{ "key_code": "escape" }]
                },
                {
                    "from": { "key_code": "left_command" },
                    "to": [{ "key_code": "left_option" }]
                },
                {
                    "from": { "key_code": "left_option" },
                    "to": [{ "key_code": "left_command" }]
                },
                {
                    "from": { "key_code": "left_shift" },
                    "to": [{ "key_code": "caps_lock" }]
                },
                {
                    "from": { "key_code": "right_command" },
                    "to": [{ "key_code": "left_control" }]
                },
                {
                    "from": { "key_code": "right_option" },
                    "to": [{ "key_code": "left_shift" }]
                }
            ],
            "virtual_hid_keyboard": {
                "country_code": 0,
                "indicate_sticky_modifier_keys_state": false,
                "keyboard_type_v2": "ansi"
            }
        },
        {
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "product_id": 835,
                        "vendor_id": 1452
                    },
                    "simple_modifications": [
                        {
                            "from": { "key_code": "0" },
                            "to": [{ "key_code": "6" }]
                        },
                        {
                            "from": { "key_code": "8" },
                            "to": [{ "key_code": "4" }]
                        },
                        {
                            "from": { "key_code": "9" },
                            "to": [{ "key_code": "5" }]
                        }
                    ]
                }
            ],
            "name": "New profile",
            "virtual_hid_keyboard": {
                "country_code": 0,
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}